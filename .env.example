VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:aab2a86d-a088-41e7-8e92-eeb9af4806fe
VITE_COGNITO_WEB_CLIENT_ID=6uafsoq8rlvuh3aj0opluh1l2t

