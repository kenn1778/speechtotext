# Optional: Override the API Gateway URL (defaults to deployed dev endpoint)
# API_GATEWAY_URL=https://mytne8lapa.execute-api.us-east-1.amazonaws.com/dev/transcribe

# Server port (optional, defaults to 5174)
# PORT=5174

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://yourdomain.com

# Log level: debug, info, warn, error (defaults to info)
# LOG_LEVEL=info

# Node environment (development | production)
NODE_ENV=development
