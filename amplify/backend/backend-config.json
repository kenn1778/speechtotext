{
  "api": {
    "speechwebAPI": {
      "dependsOn": [
        {
          "attributes": [
            "Arn"
          ],
          "category": "function",
          "resourceName": "speechwebTranscribe"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "API Gateway"
    },
    "speechwebTranscribeWS": {
      "dependsOn": [
        {
          "attributes": [
            "Arn"
          ],
          "category": "function",
          "resourceName": "speechwebTranscribeStream"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "API Gateway WebSocket"
    }
  },
  "auth": {
    "speechwebAuth": {
      "customAuth": false,
      "dependsOn": [],
      "frontendAuthConfig": {
        "mfaConfiguration": "OFF",
        "mfaTypes": [],
        "passwordProtectionSettings": {
          "passwordPolicyCharacters": [],
          "passwordPolicyMinLength": 8
        },
        "signupAttributes": [
          "email",
          "name"
        ],
        "socialProviders": [
          "GOOGLE"
        ],
        "usernameAttributes": [
          "email"
        ],
        "verificationMechanisms": [
          "email"
        ]
      },
      "providerPlugin": "awscloudformation",
      "service": "Cognito",
      "serviceType": "managed"
    }
  },
  "function": {
    "speechwebTranscribe": {
      "build": true,
      "dependsOn": [
        {
          "attributes": [
            "BucketName"
          ],
          "category": "storage",
          "resourceName": "speechwebStorage"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "Lambda"
    },
    "speechwebTranscribeStream": {
      "build": true,
      "dependsOn": [
        {
          "attributes": [
            "BucketName"
          ],
          "category": "storage",
          "resourceName": "speechwebStorage"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "Lambda"
    }
  },
  "hosting": {
    "S3AndCloudFront": {
      "providerPlugin": "awscloudformation",
      "service": "S3AndCloudFront"
    }
  },
  "storage": {
    "speechwebStorage": {
      "dependsOn": [
        {
          "attributes": [
            "UserPoolId",
            "AppClientID",
            "IdentityPoolId"
          ],
          "category": "auth",
          "resourceName": "speechwebAuth"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "S3",
      "serviceType": "managed"
    }
  }
}